          },
          "repoName" : {
            "type" : "string",
            "description" : "仓库名称，为后续同步预留"
          },
          "repoOwner" : {
            "type" : "string",
            "description" : "仓库所有者，为后续同步预留"
          },
          "repoUrl" : {
            "type" : "string",
            "description" : "仓库地址"
